{% extends 'base.html.twig' %}

{% block title %}Liste des articles{% endblock %}

{% block body %}
    <section class="page-card">
        <div class="page-header">
            <div>
                <h1>Liste des articles</h1>
                <p class="page-intro">Consultez, modifiez et ajoutez facilement vos articles.</p>
            </div>

            <div class="actions">
                <a class="btn btn-primary" href="{{ path('app_index_new') }}">Ajouter un article</a>
            </div>
        </div>

        {# Search by name form #}
 <div class="row mb-4">
 <div class="col-md-6">
 {{ form_start(form) }}
 <div class="input-group">
 {{ form_widget(form.nom, {'attr': {'class': 'form-control',
'placeholder': 'Rechercher par nom...'}}) }}
 <button type="submit" class="btn btn-primary">Rechercher</button>
 </div>
 {{ form_end(form) }}
 </div>
 </div>


        <div class="table-wrapper">
            <table class="table">
                <thead>
                    <tr>
                        <th>Id</th>
                        <th>Nom</th>
                        <th>Prix</th>
                        <th>Categorie</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for article in articles %}
                    <tr>
                        <td>{{ article.id }}</td>
                        <td>{{ article.nom }}</td>
                        <td>{{ article.prix }}</td>
                        <td>{{ article.category ? article.category.titre : 'Aucune' }}</td>
                        <td>
                            <div class="table-actions">
                                <a class="link-inline" href="{{ path('app_index_show', {'id': article.id}) }}">Voir</a>
                                <a class="link-inline" href="{{ path('app_index_edit', {'id': article.id}) }}">Modifier</a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="empty-state">Aucun article trouve pour le moment.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
